<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  
  # Redirect /index.html to / (except for actual file requests)
  RewriteRule ^index\.html$ / [R=301,L]
  
  # If the requested resource is not a file and not a directory...
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  
  # ...then rewrite it to index.html (Next.js SPA routing)
  RewriteRule . /index.html [L]
</IfModule>
